@model List<MrMohamedHassan.Models.Attendance>
@{
    ViewData["Title"] = "التقرير اليومي للحضور";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">التقرير اليومي للحضور</h2>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">المجموعة</label>
                <select name="groupId" class="form-select">
                    <option value="">-- اختر المجموعة --</option>
                    @foreach (var group in (IEnumerable<dynamic>)ViewBag.Groups)
                    {
                        <option value="@group.Id">@group.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">التاريخ</label>
                <input type="date" name="date" value="@ViewBag.SelectedDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search ms-2"></i>عرض</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-vcenter card-table">
                <thead>
                    <tr><th>الطالب</th><th>الكود</th><th>المجموعة</th><th>الحالة</th><th>التاريخ</th></tr>
                </thead>
                <tbody>
                    @foreach (var att in Model)
                    {
                        <tr>
                            <td>@att.Student?.FullName</td>
                            <td><span class="badge bg-azure-lt">@att.Student?.StudentCode</span></td>
                            <td>@att.Group?.Name</td>
                            <td>
                                @switch (att.Status)
                                {
                                    case MrMohamedHassan.Models.AttendanceStatus.Present:
                                        <span class="badge bg-success-lt">حاضر</span>
                                        break;
                                    case MrMohamedHassan.Models.AttendanceStatus.Absent:
                                        <span class="badge bg-danger-lt">غائب</span>
                                        break;
                                    case MrMohamedHassan.Models.AttendanceStatus.Late:
                                        <span class="badge bg-warning-lt">متأخر</span>
                                        break;
                                }
                            </td>
                            <td>@att.Date.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
