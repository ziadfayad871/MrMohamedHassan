@model MrMohamedHassan.ViewModels.PaymentCreateViewModel
@{ ViewData["Title"] = "تسجيل دفعة"; }
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header"><h3 class="card-title"><i class="fas fa-money-bill-wave ms-2"></i>تسجيل دفعة</h3></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StudentId" class="form-label"></label>
                            <select asp-for="StudentId" asp-items="@(new SelectList((IEnumerable<dynamic>)ViewBag.Students, "Id", "FullName"))" class="form-select"><option value="">-- اختر الطالب --</option></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Discount" class="form-label"></label>
                            <input asp-for="Discount" type="number" step="0.01" class="form-control" value="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PaymentType" class="form-label"></label>
                            <select asp-for="PaymentType" class="form-select">
                                <option value="Subscription">اشتراك</option><option value="Partial">دفعة جزئية</option><option value="Extra">رسوم إضافية</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PaymentMethod" class="form-label"></label>
                            <select asp-for="PaymentMethod" class="form-select">
                                <option value="Cash">نقدي</option><option value="BankTransfer">تحويل بنكي</option><option value="VodafoneCash">فودافون كاش</option><option value="Online">الدفع الإلكتروني</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PaymentDate" class="form-label"></label>
                            <input asp-for="PaymentDate" type="date" class="form-control" />
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save ms-2"></i>حفظ</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
