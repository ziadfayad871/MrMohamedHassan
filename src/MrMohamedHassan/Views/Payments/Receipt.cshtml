@model MrMohamedHassan.ViewModels.PaymentReceiptViewModel
@{ ViewData["Title"] = "إيصال الدفع"; Layout = null; }
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" /><title>إيصال - @Model.ReceiptNumber</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body{font-family:'Cairo',sans-serif;direction:rtl;padding:40px}
        .receipt{max-width:500px;margin:0 auto;border:2px solid #333;padding:30px}
        .receipt-header{text-align:center;border-bottom:2px dashed #ccc;padding-bottom:15px;margin-bottom:15px}
        .receipt-row{display:flex;justify-content:space-between;margin-bottom:8px;padding:5px 0;border-bottom:1px dotted #eee}
        .receipt-total{font-size:1.2rem;font-weight:bold;border-top:2px solid #333;padding-top:10px;margin-top:10px}
        .print-btn{display:block;margin:20px auto;padding:10px 30px;background:#3b82f6;color:white;border:none;border-radius:8px;cursor:pointer;font-family:'Cairo'}
        @@media print{.print-btn{display:none}}
    </style>
</head>
<body>
    <div class="receipt">
        <div class="receipt-header"><h1>@Model.CenterName</h1><p>@Model.CenterPhone</p><h2>إيصال دفع</h2></div>
        <div class="receipt-row"><span>رقم الإيصال:</span><span>@Model.ReceiptNumber</span></div>
        <div class="receipt-row"><span>التاريخ:</span><span>@Model.PaymentDate.ToString("yyyy-MM-dd")</span></div>
        <div class="receipt-row"><span>اسم الطالب:</span><span>@Model.StudentName</span></div>
        <div class="receipt-row"><span>كود الطالب:</span><span>@Model.StudentCode</span></div>
        <div class="receipt-row"><span>نوع الدفعة:</span><span>@Model.PaymentType</span></div>
        <div class="receipt-row"><span>طريقة الدفع:</span><span>@Model.PaymentMethod</span></div>
        <div class="receipt-row"><span>المبلغ:</span><span>@Model.Amount.ToString("N2") ج.م</span></div>
        <div class="receipt-row"><span>الخصم:</span><span>@Model.Discount.ToString("N2") ج.م</span></div>
        <div class="receipt-row receipt-total"><span>المدفوع:</span><span>@Model.PaidAmount.ToString("N2") ج.م</span></div>
    </div>
    <button class="print-btn" onclick="window.print()">طباعة</button>
</body>
</html>
