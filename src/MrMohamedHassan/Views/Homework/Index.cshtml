@model List<MrMohamedHassan.ViewModels.HomeworkListViewModel>
@{ ViewData["Title"] = "الواجبات"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">الواجبات</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus ms-2"></i>إنشاء واجب</a>
</div>
<div class="row">
    @foreach (var h in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">@h.Title</h5>
                    <p class="text-muted text-sm">@h.Description</p>
                    <div class="mb-2"><span class="text-muted">المجموعة:</span> <span class="badge bg-primary-lt">@h.GroupName</span></div>
                    <div class="mb-2"><span class="text-muted">التسليم:</span> @h.DueDate.ToString("yyyy-MM-dd")</div>
                    <div class="mb-2"><span class="text-muted">التسليمات:</span> @h.SubmissionsCount / @h.TotalStudents</div>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Submissions" asp-route-id="@h.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-list ms-1"></i>التسليمات</a>
                    <form asp-action="Delete" asp-route-id="@h.Id" method="post" style="display:inline"><button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('هل أنت متأكد؟')"><i class="fas fa-trash"></i></button></form>
                </div>
            </div>
        </div>
    }
</div>
