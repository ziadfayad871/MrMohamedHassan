@model MrMohamedHassan.ViewModels.ExpenseCreateViewModel
@{ ViewData["Title"] = "إضافة مصروف"; }
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header"><h3 class="card-title"><i class="fas fa-receipt ms-2"></i>إضافة مصروف</h3></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3"><label asp-for="Description" class="form-label"></label><input asp-for="Description" class="form-control" /><span asp-validation-for="Description" class="text-danger"></span></div>
                        <div class="col-md-6 mb-3"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" type="number" step="0.01" class="form-control" /><span asp-validation-for="Amount" class="text-danger"></span></div>
                        <div class="col-md-6 mb-3"><label asp-for="ExpenseCategoryId" class="form-label">الفئة</label><select asp-for="ExpenseCategoryId" asp-items="@(new SelectList((IEnumerable<dynamic>)ViewBag.Categories, "Id", "Name"))" class="form-select"><option value="">-- اختر الفئة --</option></select></div>
                        <div class="col-md-6 mb-3"><label asp-for="ExpenseDate" class="form-label"></label><input asp-for="ExpenseDate" type="date" class="form-control" /></div>
                        <div class="col-12 mb-3"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save ms-2"></i>حفظ</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
