@model List<MrMohamedHassan.ViewModels.GroupListViewModel>
@{
    ViewData["Title"] = "المجموعات";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">المجموعات</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus ms-2"></i>إنشاء مجموعة</a>
</div>

<div class="row">
    @foreach (var group in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h4 class="card-title mb-0">@group.Name</h4>
                        <span class="badge @(group.IsActive ? "bg-success-lt" : "bg-secondary-lt")">@(group.IsActive ? "نشطة" : "غير نشطة")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(group.Subject))
                    {
                        <p class="text-muted mb-1"><i class="fas fa-book ms-2"></i>@group.Subject</p>
                    }
                    <p class="text-muted mb-1"><i class="fas fa-chalkboard-teacher ms-2"></i>@group.TeacherName</p>
                    @if (group.ScheduleDays != null)
                    {
                        <p class="text-muted mb-1"><i class="fas fa-calendar ms-2"></i>@group.ScheduleDays</p>
                    }
                    @if (group.StartTime.HasValue && group.EndTime.HasValue)
                    {
                        <p class="text-muted mb-1"><i class="fas fa-clock ms-2"></i>@group.StartTime.Value.ToString(@"hh\:mm") - @group.EndTime.Value.ToString(@"hh\:mm")</p>
                    }
                    <p class="text-muted mb-3"><i class="fas fa-users ms-2"></i>@group.EnrolledCount / @group.Capacity طالب</p>
                    <div class="d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@group.Id" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                        <form asp-action="Delete" asp-route-id="@group.Id" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('هل أنت متأكد؟')"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="fas fa-layer-group text-muted mb-3" style="font-size:3rem"></i>
            <p class="text-muted">لا توجد مجموعات بعد</p>
            <a asp-action="Create" class="btn btn-primary">إنشاء مجموعة جديدة</a>
        </div>
    </div>
}
