@model MrMohamedHassan.ViewModels.StudentEditViewModel
@{
    ViewData["Title"] = "تعديل بيانات الطالب";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-edit ms-2"></i>تعديل بيانات الطالب - @Model.StudentCode</h3>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="StudentCode" />
                    <input type="hidden" asp-for="ExistingImageUrl" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ParentName" class="form-label"></label>
                            <input asp-for="ParentName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ParentPhone" class="form-label"></label>
                            <input asp-for="ParentPhone" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="School" class="form-label"></label>
                            <input asp-for="School" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Grade" class="form-label"></label>
                            <input asp-for="Grade" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="BirthDate" class="form-label"></label>
                            <input asp-for="BirthDate" type="date" class="form-control" lang="en" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Gender" class="form-label"></label>
                            <select asp-for="Gender" class="form-select">
                                <option value="Male">ذكر</option>
                                <option value="Female">أنثى</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="JoinDate" class="form-label"></label>
                            <input asp-for="JoinDate" type="date" class="form-control" lang="en" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SubscriptionFee" class="form-label"></label>
                            <input asp-for="SubscriptionFee" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Active">نشط</option>
                                <option value="Inactive">غير نشط</option>
                                <option value="Withdrawn">منسحب</option>
                                <option value="Graduated">متخرج</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="StudentImage" class="form-label">صورة جديدة</label>
                            <input asp-for="StudentImage" type="file" class="form-control" accept="image/*" />
                            @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                            {
                                <div class="mt-2"><img src="@Model.ExistingImageUrl" class="avatar" alt="" /></div>
                            }
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save ms-2"></i>حفظ التعديلات</button>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right ms-2"></i>رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
