@model MrMohamedHassan.ViewModels.StudentCreateViewModel
@{
    ViewData["Title"] = "إضافة طالب جديد";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-user-plus ms-2"></i>إضافة طالب جديد</h3>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ParentName" class="form-label"></label>
                            <input asp-for="ParentName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ParentPhone" class="form-label"></label>
                            <input asp-for="ParentPhone" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="School" class="form-label"></label>
                            <input asp-for="School" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Grade" class="form-label"></label>
                            <input asp-for="Grade" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="BirthDate" class="form-label"></label>
                            <input asp-for="BirthDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Gender" class="form-label"></label>
                            <select asp-for="Gender" class="form-select">
                                <option value="Male">ذكر</option>
                                <option value="Female">أنثى</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="JoinDate" class="form-label"></label>
                            <input asp-for="JoinDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SubscriptionFee" class="form-label"></label>
                            <input asp-for="SubscriptionFee" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Active">نشط</option>
                                <option value="Inactive">غير نشط</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="StudentImage" class="form-label"></label>
                            <input asp-for="StudentImage" type="file" class="form-control" accept="image/*" />
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label">المجموعات</label>
                            <select asp-for="SelectedGroupIds" asp-items="@(new SelectList((IEnumerable<dynamic>)ViewBag.Groups, "Id", "Name"))" multiple class="form-select" size="4"></select>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save ms-2"></i>حفظ</button>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right ms-2"></i>رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
