@model MrMohamedHassan.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="dashboard-grid dashboard-grid-4 mb-4" style="animation:staggerFade 0.6s ease;">
    <div class="card" style="padding:1.25rem;--delay:0.05s;">
        <div style="display:flex;align-items:center;gap:1rem;">
            <div class="stat-icon blue"><i class="fas fa-user-graduate"></i></div>
            <div>
                <div class="stat-label">عدد الطلاب</div>
                <div class="stat-value counter" data-target="@Model.TotalStudents">0</div>
            </div>
        </div>
    </div>
    <div class="card" style="padding:1.25rem;--delay:0.1s;">
        <div style="display:flex;align-items:center;gap:1rem;">
            <div class="stat-icon green"><i class="fas fa-layer-group"></i></div>
            <div>
                <div class="stat-label">المجموعات</div>
                <div class="stat-value counter" data-target="@Model.TotalGroups">0</div>
            </div>
        </div>
    </div>
    <div class="card" style="padding:1.25rem;--delay:0.15s;">
        <div style="display:flex;align-items:center;gap:1rem;">
            <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
            <div>
                <div class="stat-label">حضور اليوم</div>
                <div class="stat-value counter" data-target="@Model.TodayPresent">0</div>
            </div>
        </div>
    </div>
    <div class="card" style="padding:1.25rem;--delay:0.2s;">
        <div style="display:flex;align-items:center;gap:1rem;">
            <div class="stat-icon red"><i class="fas fa-times-circle"></i></div>
            <div>
                <div class="stat-label">غياب اليوم</div>
                <div class="stat-value counter" data-target="@Model.TodayAbsent">0</div>
            </div>
        </div>
    </div>
</div>

<div class="dashboard-grid mb-4" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;">
    <div class="mini-stat" style="--delay:0.25s;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
            <div class="mini-stat-icon" style="background:#eff6ff;color:var(--primary);"><i class="fas fa-dollar-sign"></i></div>
            <div>
                <div class="mini-stat-value" style="color:var(--success);">@Model.MonthlyRevenue.ToString("N0") ج.م</div>
                <div class="mini-stat-label">إيرادات الشهر</div>
            </div>
        </div>
    </div>
    <div class="mini-stat" style="--delay:0.3s;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
            <div class="mini-stat-icon" style="background:#fef2f2;color:var(--danger);"><i class="fas fa-shopping-cart"></i></div>
            <div>
                <div class="mini-stat-value" style="color:var(--danger);">@Model.MonthlyExpenses.ToString("N0") ج.م</div>
                <div class="mini-stat-label">مصروفات الشهر</div>
            </div>
        </div>
    </div>
    <div class="mini-stat" style="--delay:0.35s;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
            <div class="mini-stat-icon" style="background:#f0fdf4;color:var(--success);"><i class="fas fa-chart-line"></i></div>
            <div>
                <div class="mini-stat-value" style="color:@(Model.NetProfit >= 0 ? "var(--success)" : "var(--danger)");">@Model.NetProfit.ToString("N0") ج.م</div>
                <div class="mini-stat-label">صافي الربح</div>
            </div>
        </div>
    </div>
</div>

<div class="dashboard-grid dashboard-grid-2 mb-4">
    <div class="card" style="--delay:0.4s;">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-chart-bar ms-1" style="color:var(--primary)"></i> إيرادات آخر 6 شهور</h5>
        </div>
        <div class="card-body">
            <div class="chart-container">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>
    <div class="card" style="--delay:0.45s;">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-chart-pie ms-1" style="color:var(--primary)"></i> نسبة الحضور</h5>
        </div>
        <div class="card-body">
            <div class="chart-container">
                <canvas id="attendanceChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="dashboard-grid" style="grid-template-columns:repeat(auto-fit,minmax(350px,1fr));gap:1rem;">
    <div class="card" style="--delay:0.5s;">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-chart-line ms-1" style="color:var(--primary)"></i> نمو الطلاب</h5>
        </div>
        <div class="card-body">
            <div class="chart-container">
                <canvas id="studentGrowthChart"></canvas>
            </div>
        </div>
    </div>
    <div class="card" style="--delay:0.55s;">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-layer-group ms-1" style="color:var(--primary)"></i> المجموعات النشطة</h5>
            <a asp-controller="Groups" asp-action="Index" class="btn btn-outline-primary btn-sm">عرض الكل</a>
        </div>
        <div style="padding:0;">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>المجموعة</th>
                        <th>المادة</th>
                        <th>المعلم</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
@@keyframes staggerFade {
    from { opacity: 0; }
    to { opacity: 1; }
}
.card, .mini-stat {
    animation: cardEntrance 0.5s ease both;
    animation-delay: var(--delay, 0s);
}
@@keyframes cardEntrance {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>

@section Scripts {
<script>
    var revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueChart));
    var attendanceData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyAttendanceChart));
    var studentGrowthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StudentGrowthChart));

    var revenueCtx = document.getElementById('revenueChart');
    new Chart(revenueCtx, {
        type: 'bar',
        data: {
            labels: Object.keys(revenueData),
            datasets: [{
                label: 'الإيرادات (ج.م)',
                data: Object.values(revenueData),
                backgroundColor: '#3b82f6',
                borderRadius: 4,
                animation: {
                    duration: 1000,
                    easing: 'easeOutQuart'
                }
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                x: { grid: { display: false } }
            }
        }
    });

    var attCtx = document.getElementById('attendanceChart');
    new Chart(attCtx, {
        type: 'doughnut',
        data: {
            labels: ['حضور', 'غياب'],
            datasets: [{
                data: [@Model.TodayPresent, @Model.TodayAbsent],
                backgroundColor: ['#16a34a', '#dc2626'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            cutout: '65%',
            plugins: { legend: { position: 'bottom' } },
            animation: {
                animateRotate: true,
                duration: 1200
            }
        }
    });

    var growthCtx = document.getElementById('studentGrowthChart');
    new Chart(growthCtx, {
        type: 'line',
        data: {
            labels: Object.keys(studentGrowthData),
            datasets: [{
                label: 'طلاب جدد',
                data: Object.values(studentGrowthData),
                borderColor: '#1a56db',
                backgroundColor: 'rgba(26,86,219,0.08)',
                fill: true, tension: 0.3,
                borderWidth: 2,
                pointRadius: 3,
                pointBackgroundColor: '#1a56db'
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                x: { grid: { display: false } }
            },
            animation: {
                duration: 1500,
                easing: 'easeOutQuart'
            }
        }
    });

    function animateCounters() {
        var counters = document.querySelectorAll('.counter');
        counters.forEach(function(el) {
            var target = parseInt(el.getAttribute('data-target'));
            if (isNaN(target) || target === 0) { el.textContent = '0'; return; }
            var duration = 1200, steps = 30;
            var increment = target / steps;
            var current = 0, step = 0;
            function tick() {
                step++;
                current = Math.min(Math.round(increment * step), target);
                el.textContent = current.toLocaleString('ar-EG');
                if (current < target) requestAnimationFrame(tick);
            }
            tick();
        });
    }

    setTimeout(animateCounters, 300);
</script>
}
