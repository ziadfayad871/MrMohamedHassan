@model MrMohamedHassan.ViewModels.ExamResultsViewModel
@{ ViewData["Title"] = $"نتائج - {Model.ExamTitle}"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">نتائج: @Model.ExamTitle</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
</div>
<form asp-action="SaveResults" method="post">
    <input type="hidden" name="examId" value="@Model.ExamId" />
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-vcenter card-table">
                <thead><tr><th>الطالب</th><th>الكود</th><th>الدرجة</th><th>الحالة</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < Model.Results.Count; i++)
                    {
                        <tr>
                            <input type="hidden" name="results[@i].StudentId" value="@Model.Results[i].StudentId" />
                            <td>@Model.Results[i].StudentName</td>
                            <td><span class="badge bg-azure-lt">@Model.Results[i].StudentCode</span></td>
                            <td><input type="number" name="results[@i].MarksObtained" value="@Model.Results[i].MarksObtained" max="@Model.MaxMarks" min="0" class="form-control form-control-sm" style="width:100px" /></td>
                            <td>@(Model.Results[i].MarksObtained >= Model.PassMarks ? "ناجح" : "راسب")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer"><button type="submit" class="btn btn-primary"><i class="fas fa-save ms-2"></i>حفظ النتائج</button></div>
    </div>
</form>
