@model MrMohamedHassan.ViewModels.ExamCreateViewModel
@{ ViewData["Title"] = "إنشاء امتحان"; }
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header"><h3 class="card-title"><i class="fas fa-file-alt ms-2"></i>إنشاء امتحان</h3></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /><span asp-validation-for="Title" class="text-danger"></span></div>
                        <div class="col-md-6 mb-3"><label asp-for="GroupId" class="form-label"></label><select asp-for="GroupId" asp-items="@(new SelectList((IEnumerable<dynamic>)ViewBag.Groups, "Id", "Name"))" class="form-select"><option value="">-- اختر المجموعة --</option></select></div>
                        <div class="col-md-6 mb-3"><label asp-for="ExamDate" class="form-label"></label><input asp-for="ExamDate" type="date" class="form-control" /></div>
                        <div class="col-md-3 mb-3"><label asp-for="MaxMarks" class="form-label"></label><input asp-for="MaxMarks" type="number" class="form-control" /></div>
                        <div class="col-md-3 mb-3"><label asp-for="PassMarks" class="form-label"></label><input asp-for="PassMarks" type="number" class="form-control" /></div>
                        <div class="col-12 mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save ms-2"></i>إنشاء</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
