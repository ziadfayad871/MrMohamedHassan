@model List<MrMohamedHassan.Models.ExamResult>
@{ ViewData["Title"] = "ترتيب الطلاب"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-trophy text-warning ms-2"></i>ترتيب الطلاب</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
</div>
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-vcenter card-table">
            <thead><tr><th>#</th><th>الطالب</th><th>الدرجة</th></tr></thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@(rank <= 3 ? rank.ToString() : rank.ToString())</td>
                        <td class="fw-bold">@r.Student?.FullName</td>
                        <td>@r.MarksObtained / @r.Exam?.MaxMarks</td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
</div>
