@model List<MrMohamedHassan.ViewModels.PaymentListViewModel>
@{ ViewData["Title"] = "المدفوعات"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">المدفوعات</h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus ms-2"></i>تسجيل دفعة</a>
        <a asp-action="ExportExcel" class="btn btn-success"><i class="fas fa-file-excel ms-2"></i>تصدير Excel</a>
    </div>
</div>
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-vcenter card-table">
            <thead>
                <tr><th>الطالب</th><th>الكود</th><th>المبلغ</th><th>الخصم</th><th>المدفوع</th><th>النوع</th><th>طريقة الدفع</th><th>التاريخ</th><th>رقم الإيصال</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.StudentName</td>
                        <td><span class="badge bg-azure-lt">@p.StudentCode</span></td>
                        <td>@p.Amount.ToString("N0")</td>
                        <td>@p.Discount.ToString("N0")</td>
                        <td class="text-success fw-bold">@p.PaidAmount.ToString("N0")</td>
                        <td>@p.PaymentType</td>
                        <td>@p.PaymentMethod</td>
                        <td>@p.PaymentDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge bg-info-lt">@p.ReceiptNumber</span></td>
                        <td><a asp-action="Receipt" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-receipt"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@if ((int)ViewBag.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination justify-content-center">
        @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
        { <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i">@i</a></li> }
    </ul></nav>
}
