@model List<MrMohamedHassan.ViewModels.HomeworkSubmissionViewModel>
@{ ViewData["Title"] = $"تسليمات - {ViewBag.HomeworkTitle}"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">تسليمات: @ViewBag.HomeworkTitle</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
</div>
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-vcenter card-table">
            <thead><tr><th>الطالب</th><th>تاريخ التسليم</th><th>الدرجة</th><th>ملاحظات</th><th>الحالة</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="fw-bold">@s.StudentName</td>
                        <td>@s.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(s.Marks?.ToString() ?? "-") / @ViewBag.MaxMarks</td>
                        <td>@s.TeacherComments</td>
                        <td>@(s.IsGraded ? "تم التصحيح" : "بانتظار التصحيح")</td>
                        <td>
                            <form asp-action="Grade" method="post" class="d-flex gap-1">
                                <input type="hidden" name="submissionId" value="@s.StudentId" />
                                <input type="hidden" name="homeworkId" value="@s.HomeworkId" />
                                <input type="number" name="marks" max="@ViewBag.MaxMarks" min="0" class="form-control form-control-sm" style="width:80px" placeholder="الدرجة" />
                                <input type="text" name="comments" class="form-control form-control-sm" style="width:150px" placeholder="ملاحظات" />
                                <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-check"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
