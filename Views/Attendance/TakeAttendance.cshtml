@model MrMohamedHassan.ViewModels.AttendanceTakeViewModel
@{
    ViewData["Title"] = "تسجيل الحضور";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">تسجيل الحضور</h2>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">المجموعة</label>
                <select name="groupId" class="form-select">
                    <option value="">-- اختر المجموعة --</option>
                    @foreach (var group in (IEnumerable<dynamic>)ViewBag.Groups)
                    {
                        <option value="@group.Id" selected="@(Model.GroupId == group.Id)">@group.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">التاريخ</label>
                <input type="date" name="date" value="@ViewBag.SelectedDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary"><i class="fas fa-search ms-2"></i>عرض</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Students.Any())
{
    <form asp-action="TakeAttendance" method="post">
        <input type="hidden" asp-for="GroupId" />
        <input type="hidden" asp-for="Date" />

        <div class="card border-0 shadow-sm">
            <div class="card-header">
                <h4 class="card-title">الطلاب - @Model.Students.Count طالب</h4>
                <button type="submit" class="btn btn-primary btn-sm ms-auto"><i class="fas fa-save ms-2"></i>حفظ الحضور</button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-vcenter card-table">
                    <thead>
                        <tr>
                            <th>الطالب</th>
                            <th>الكود</th>
                            <th>الحالة</th>
                            <th>ملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Students.Count; i++)
                        {
                            <tr>
                                <input type="hidden" asp-for="Students[@i].StudentId" />
                                <input type="hidden" asp-for="Students[@i].StudentName" />
                                <input type="hidden" asp-for="Students[@i].StudentCode" />
                                <td class="fw-bold">@Model.Students[i].StudentName</td>
                                <td><span class="badge bg-azure-lt">@Model.Students[i].StudentCode</span></td>
                                <td>
                                    <select asp-for="Students[@i].Status" class="form-select form-select-sm">
                                        <option value="Present">حاضر</option>
                                        <option value="Absent">غائب</option>
                                        <option value="Late">متأخر</option>
                                    </select>
                                </td>
                                <td><input asp-for="Students[@i].Notes" class="form-control form-control-sm" placeholder="ملاحظات..." /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </form>
}
else if (Model.GroupId > 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="fas fa-users text-muted mb-3" style="font-size:3rem"></i>
            <p class="text-muted">لا يوجد طلاب في هذه المجموعة</p>
        </div>
    </div>
}
