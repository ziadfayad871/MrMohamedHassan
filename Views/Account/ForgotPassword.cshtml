@model MrMohamedHassan.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "نسيت كلمة المرور";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h1 class="h3 fw-bold">نسيت كلمة المرور</h1>
                    <p class="text-muted">أدخل بريدك الإلكتروني وسنرسل لك رابط إعادة تعيين كلمة المرور</p>
                </div>
                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control form-control-lg" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-paper-plane ms-2"></i>إرسال
                    </button>
                </form>
                <div class="text-center mt-3">
                    <a asp-action="Login" class="text-muted">العودة لتسجيل الدخول</a>
                </div>
            </div>
        </div>
    </div>
</div>
